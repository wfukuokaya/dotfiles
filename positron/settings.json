  "workbench.iconTheme": "vs-minimal",
  "terminal.integrated.lineHeight": 1.12,
  "editor.fontWeight": "1",
  "terminal.integrated.fontWeight": "1",
  "editor.renderWhitespace": "none",
  "editor.minimap.sectionHeaderLetterSpacing": -0.5,
  "editor.fontLigatures": true,
  "terminal.integrated.fontLigatures.enabled": false,
  "console.fontLigatures": true,
  "positron.assistant.provider.anthropic.enable": true,
  "custom-ui-style.electron": {
    ".integrated-terminal .xterm-viewport": "padding-bottom: 16px !important;"
  },
  "custom-ui-style.stylesheet": {},
  "custom-ui-style.preferRestart": true,
  "terminal.integrated.fontLigatures.featureSettings": "\"calt\" off",
  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 1000,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "explicit",
  "editor.letterSpacing": -0.25,
  "console.letterSpacing": -0.5,
  "window.zoomLevel": -0.4,
  "custom-ui-style.font.monospace": "'UDEV Gothic 35NFLG'",
  "terminal.integrated.initialHint": false,
  "workbench.editor.enablePreview": false,
  "workbench.topActionBar.visible": false,
  "breadcrumbs.enabled": false,
  "workbench.activityBar.location": "top",
  "voicetotext.model": "large-v3-turbo",
  "task.allowAutomaticTasks": "off",
  "diffEditor.codeLens": true,
  "diffEditor.experimental.useTrueInlineView": false,
  "githubPullRequests.quickDiff": true,
  "merge-conflict.diffViewPosition": "Beside",
  "quarto.visualEditor.defaultListSpacing": "tight",
  "codeCells.cellStyle": "border",
  "quarto.visualEditor.lineNumbers": false,
  "quarto.visualEditor.spelling": false,
  "quarto.visualEditor.fontSize": 13,
  "workbench.statusBar.visible": false
}
