{
  "workbench.colorTheme": "Fukuokaya Dark",
  "security.workspace.trust.untrustedFiles": "open",
  "update.mode": "manual",
  "files.associations": {
    "renv.lock": "json"
  },
  "positron.assistant.enable": true,
  "positron.assistant.followups.enable": true,
  "editor.dropIntoEditor.preferences": [],
  "editor.formatOnPaste": true,
  "workbench.settings.applyToAllProfiles": [
    "editor.fontFamily",
    "quarto.cells.background.darkDefault",
    "quarto.visualEditor.defaultListSpacing"
  ],
  "console.fontFamily": "'UDEV Gothic 35NFLG', 'JetBrains Mono', Menlo, Monaco, 'Courier New', monospace",
  "editor.fontFamily": "'UDEV Gothic 35NFLG', 'JetBrains Mono', Monaco, 'Courier New', monospace, 'Cascadia Code', 'Fira Code'",
  "claudeCode.preferredLocation": "sidebar",
  "claudeCode.selectedModel": "default",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "git.openAfterClone": "alwaysNewWindow",
  "claude.mcpServers": {
    "zotero": {
      "command": "npx",
      "args": [
        "-y",
        "@grantcarthew/zotero-mcp"
      ]
    }
  },
  "scm.inputFontFamily": "'UDEV Gothic 35NFLG'",
  "debug.console.fontFamily": "'UDEV Gothic 35NFLG'",
  "editor.inlineSuggest.fontFamily": "'UDEV Gothic 35NFLG'",
  "terminal.integrated.fontFamily": "'UDEV Gothic 35NFLG'",
  "notebook.markup.fontFamily": "'UDEV Gothic 35NFLG'",
  "chat.fontFamily": "'UDEV Gothic 35NFLG'",
  "chat.editor.fontFamily": "'UDEV Gothic 35NFLG'",
  "notebook.output.fontFamily": "'UDEV Gothic 35NFLG'",
  "editor.codeLensFontFamily": "'UDEV Gothic 35NFLG'",
  "editor.inlayHints.fontFamily": "'UDEV Gothic 35NFLG'",
  "custom-ui-style.font.sansSerif": "'UDEV Gothic 35NFLG'",
  "quarto.visualEditor.maxContentWidth": 10000,
  "editor.suggest.showStatusBar": true,
  "notebook.markup.fontSize": 14,
  "editor.suggestFontSize": 14,
  "chat.editor.wordWrap": "on",
  "quarto.visualEditor.fontFamily": "'UDEV Gothic 35NFLG'",
  "markdown.preview.lineHeight": 1.2,
  "debug.console.fontSize": 14,
  "console.fontSize": 14,
  "chat.editor.fontSize": 14,
  "editor.fontSize": 14.5,
  "scm.inputFontSize": 14,
  "terminal.integrated.fontSize": 14.5,
  "chat.fontSize": 14,
  "console.lineHeight": 1,
  "editor.lineHeight": 1.25,
  "editor.suggestLineHeight": 25,
  "notebook.output.fontSize": 14,
  "quarto.render.previewType": "external",
  "quarto.render.previewReveal": false,
  "quarto.visualEditor.markdownWrapColumn": 100,
  "claudeCode.useCtrlEnterToSend": true,
  "claudeCode.useTerminal": false,
  "editor.cursorStyle": "block",
  "workbench.preferredHighContrastColorTheme": "Default Positron Dark",
  "workbench.iconTheme": "vs-minimal",
  "terminal.integrated.lineHeight": 1.05,
  "editor.fontWeight": 1,
  "terminal.integrated.fontWeight": 1,
  "editor.renderWhitespace": "none",
  "editor.minimap.sectionHeaderLetterSpacing": -0.5,
  "editor.fontLigatures": true,
  "terminal.integrated.fontLigatures.enabled": false,
  "console.fontLigatures": true,
  "positron.assistant.provider.anthropic.enable": true,
  "terminal.integrated.fontLigatures.featureSettings": "\"calt\" off",
  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 1000,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "explicit",
  "editor.letterSpacing": -0.2,
  "console.letterSpacing": -0.5,
  "window.zoomLevel": -0.4,
  "terminal.integrated.initialHint": false,
  "workbench.editor.enablePreview": false,
  "workbench.topActionBar.visible": false,
  "breadcrumbs.enabled": false,
  "workbench.activityBar.location": "hidden",
  "voicetotext.model": "large-v3-turbo",
  "task.allowAutomaticTasks": "off",
  "diffEditor.codeLens": true,
  "diffEditor.experimental.useTrueInlineView": false,
  "githubPullRequests.quickDiff": true,
  "merge-conflict.diffViewPosition": "Beside",
  "quarto.visualEditor.defaultListSpacing": "tight",
  "codeCells.cellStyle": "border",
  "quarto.visualEditor.lineNumbers": false,
  "quarto.visualEditor.spelling": false,
  "quarto.visualEditor.fontSize": 13,
  "workbench.statusBar.visible": false,
  "terminal.integrated.gpuAcceleration": "off",
  "window.systemColorTheme": "dark",
  "window.autoDetectColorScheme": false,
  "window.titleBarStyle": "custom",
  "markdown.preview.fontSize": 14.5,
  "mermaid.gantt.fontSize": 14
}
