      "editorGroupHeader.tabsBackground": "#181818cc",
      "editorGutter.background": "#00000000",
      "editorPane.background": "#00000000",
      "input.background": "#3131314d",
      "list.activeSelectionBackground": "#04395e99",
      "list.hoverBackground": "#1F1F1F99",
      "list.inactiveSelectionBackground": "#37373d99",
      "menu.background": "#1F1F1F99",
      "multiDiffEditor.background": "#00000000",
      "multiDiffEditor.headerBackground": "#00000000",
      "notebook.cellEditorBackground": "#00000000",
      "panel.background": "#181818cc",
      "peekViewEditorGutter.background": "#00000000",
      "peekViewResult.background": "#1F1F1F4d",
      "peekViewTitle.background": "#2525264d",
      "settings.focusedRowBackground": "#00000000",
      "sideBar.background": "#181818cc",
      "sideBarSectionHeader.background": "#1818184d",
      "sideBarStickyScroll.background": "#18181866",
      "statusBar.background": "#181818cc",
      "statusBar.noFolderBackground": "#1F1F1Fcc",
      "tab.activeBackground": "#1F1F1F99",
