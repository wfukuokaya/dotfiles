{
  "workbench.colorTheme": "Fukuokaya Sage",
  "security.workspace.trust.untrustedFiles": "open",
  "update.mode": "manual",
  "files.associations": {
    "renv.lock": "json"
  },
  "positron.assistant.enable": true,
  "positron.assistant.followups.enable": true,
  "editor.dropIntoEditor.preferences": [],
  "editor.formatOnPaste": true,
  "workbench.settings.applyToAllProfiles": [
    "editor.fontFamily",
    "quarto.cells.background.darkDefault",
    "quarto.visualEditor.defaultListSpacing"
  ],
  "console.fontFamily": "'UDEV Gothic 35NFLG', 'JetBrains Mono', Menlo, Monaco, 'Courier New', monospace",
  "editor.fontFamily": "'UDEV Gothic 35NFLG', 'JetBrains Mono', Monaco, 'Courier New', monospace, 'Cascadia Code', 'Fira Code'",
  "claudeCode.preferredLocation": "sidebar",
  "claudeCode.selectedModel": "default",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "git.openAfterClone": "alwaysNewWindow",
  "claude.mcpServers": {
    "zotero": {
      "command": "npx",
      "args": [
        "-y",
        "@grantcarthew/zotero-mcp"
      ]
    }
  },
  "scm.inputFontFamily": "'UDEV Gothic 35NFLG'",
  "debug.console.fontFamily": "'UDEV Gothic 35NFLG'",
  "editor.inlineSuggest.fontFamily": "'UDEV Gothic 35NFLG'",
  "terminal.integrated.fontFamily": "'UDEV Gothic 35NFLG'",
  "notebook.markup.fontFamily": "'UDEV Gothic 35NFLG'",
  "chat.fontFamily": "'UDEV Gothic 35NFLG'",
  "chat.editor.fontFamily": "'UDEV Gothic 35NFLG'",
  "notebook.output.fontFamily": "'UDEV Gothic 35NFLG'",
  "editor.codeLensFontFamily": "'UDEV Gothic 35NFLG'",
  "editor.inlayHints.fontFamily": "'UDEV Gothic 35NFLG'",
  "quarto.visualEditor.maxContentWidth": 10000,
  "editor.suggest.showStatusBar": true,
  "notebook.markup.fontSize": 14,
  "editor.suggestFontSize": 14,
  "chat.editor.wordWrap": "on",
  "custom-ui-style.webview": {
    "stylesheet": {
      "ol": "padding-left: 1.5em !important;",
      "ol li": "margin-left: 1.0em !important;"
    }
  },
  "custom-ui-style.font.sansSerif": "'UDEV Gothic 35NFLG'",
  "quarto.visualEditor.fontFamily": "'UDEV Gothic 35NFLG'",
  "markdown.preview.lineHeight": 1.2,
  "debug.console.fontSize": 14,
  "console.fontSize": 14,
  "chat.editor.fontSize": 14,
  "editor.fontSize": 15,
  "scm.inputFontSize": 14,
  "terminal.integrated.fontSize": 15,
  "chat.fontSize": 14,
  "console.lineHeight": 1,
  "editor.lineHeight": 1.25,
  "editor.suggestLineHeight": 25,
  "notebook.output.fontSize": 14,
  "quarto.render.previewType": "external",
  "quarto.render.previewReveal": false,
  "quarto.visualEditor.markdownWrapColumn": 100,
  "claudeCode.useCtrlEnterToSend": true,
  "claudeCode.useTerminal": false,
  "editor.cursorStyle": "block",
  "workbench.preferredHighContrastColorTheme": "Default Positron Dark",
  "workbench.colorCustomizations": {
    "[Default Dark Modern]": {
      "activityBar.background": "#181818cc",
      "breadcrumb.background": "#00000000",
      "button.background": "#0078D499",
