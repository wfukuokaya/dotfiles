{
  "mcpServers": {
    "pubmed": {
      "command": "pubmed-mcp",
      "env": {
        "PUBMED_API_KEY": "<your-pubmed-api-key>",
        "PUBMED_EMAIL": "<your-email>",
        "PUBMED_CACHE_DIR": "~/.cache/pubmed-mcp"
      }
    },
    "drawio": {
      "command": "node",
      "args": ["<path-to-drawio-mcp>/src/index.js"]
    },
    "zotero": {
      "command": "zotero-mcp",
      "env": {
        "ZOTERO_LOCAL": "true",
        "ZOTERO_EMBEDDING_MODEL": "default"
      }
    }
  }
}
