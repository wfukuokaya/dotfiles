{
  "model": "opus",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch"
    ],
    "defaultMode": "default"
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": false
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "afplay /System/Library/Sounds/Morse.aiff" }]
      }
    ]
  }
}
